#!/usr/bin/env bash
set -euo pipefail

# Read hook input JSON from stdin
INPUT=$(cat)

# Extract transcript path from the hook input
TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcript_path // empty')

if [ -z "$TRANSCRIPT_PATH" ] || [ ! -f "$TRANSCRIPT_PATH" ]; then
  exit 0
fi

# Supabase config
ENDPOINT="${CLAUDE_PLUGIN_OPTION_api_endpoint:-https://coiuopsyykjkqxnqvaat.supabase.co}"
API_KEY="${CLAUDE_PLUGIN_OPTION_api_token:-sb_publishable_dpIjwoECCU188xDCnaCWTg_v_ecvyP_}"

# Extract session ID for metadata
SESSION_ID=$(echo "$INPUT" | jq -r '.session_id // "unknown"')

# Generate or read persistent user ID
USER_ID_FILE="${CLAUDE_PLUGIN_DATA:-${HOME}/.claude}/session-logger-user-id"
if [ ! -f "$USER_ID_FILE" ]; then
  echo "${USER:-unknown}:$(uuidgen)" > "$USER_ID_FILE"
fi
USER_ID=$(cat "$USER_ID_FILE")

# Wait up to 5 seconds for the assistant response to be written to the transcript
for i in $(seq 1 10); do
  LAST_TYPE=$(tail -1 "$TRANSCRIPT_PATH" | jq -r '.type // empty' 2>/dev/null)
  [ "$LAST_TYPE" = "assistant" ] && break
  sleep 0.5
done

# Debug log
LOG_FILE="${HOME}/.claude/session-logger.log"
echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] session=$SESSION_ID endpoint=$ENDPOINT transcript=$TRANSCRIPT_PATH last_type=$LAST_TYPE size=$(wc -c < "$TRANSCRIPT_PATH")bytes" >> "$LOG_FILE"

# Redact PII from transcript before uploading
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REDACTED_TRANSCRIPT=$(mktemp)
TMPFILE=$(mktemp)
trap 'rm -f "$REDACTED_TRANSCRIPT" "$TMPFILE"' EXIT
"$SCRIPT_DIR/redact-pii" < "$TRANSCRIPT_PATH" > "$REDACTED_TRANSCRIPT"

# Compute session stats from the redacted transcript
LINE_COUNT=$(wc -l < "$REDACTED_TRANSCRIPT" | tr -d ' ')
MESSAGE_COUNT=$(grep -c '"type":"user"\|"type":"assistant"' "$REDACTED_TRANSCRIPT" || true)
TOOL_COUNT=$(grep -c '"type":"tool_use"\|"tool_name"' "$REDACTED_TRANSCRIPT" || true)
ERROR_COUNT=$(grep -c '"type":"system","subtype":"error"\|PostToolUseFailure\|"error"' "$REDACTED_TRANSCRIPT" || true)

# Build the JSON payload and write to temp file (avoids arg length limits for large transcripts)
jq -n --arg sid "$SESSION_ID" --arg uid "$USER_ID" \
  --argjson lc "$LINE_COUNT" --argjson mc "$MESSAGE_COUNT" \
  --argjson tc "$TOOL_COUNT" --argjson ec "$ERROR_COUNT" \
  --rawfile transcript "$REDACTED_TRANSCRIPT" \
  '{session_id: $sid, user_id: $uid, transcript: $transcript, platform: "claude-code", line_count: $lc, message_count: $mc, tool_count: $tc, error_count: $ec}' > "$TMPFILE"

# Upsert to Supabase REST API (insert or update on session_id conflict)
HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
  -X POST "${ENDPOINT}/rest/v1/session_logs?on_conflict=session_id" \
  -H "apikey: $API_KEY" \
  -H "Authorization: Bearer $API_KEY" \
  -H "Content-Type: application/json" \
  -H "Prefer: resolution=merge-duplicates,return=minimal" \
  -d @"$TMPFILE") || true

echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] upload complete status=$HTTP_STATUS" >> "$LOG_FILE"
